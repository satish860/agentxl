# AgentXL — API Key Configuration
# Set one of these, or enter your key in the taskpane UI instead.

# Anthropic (direct)
ANTHROPIC_API_KEY=

# OpenRouter (multi-model, free tier available)
OPENROUTER_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Azure Claude (enterprise)
# ANTHROPIC_ENDPOINT=
# ANTHROPIC_API_KEY=
# ANTHROPIC_DEPLOYMENT=

# ── OCR for scanned PDFs ──
# Azure-hosted Mistral OCR (preferred for enterprise)
# AZURE_MISTRAL_ENDPOINT=https://your-instance.services.ai.azure.com/providers/mistral/azure/ocr
# AZURE_MISTRAL_API_KEY=

# Direct Mistral API (alternative)
# MISTRAL_API_KEY=
