<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="AgentXL"
    Language="1033"
    Version="$(var.AppVersion)"
    Manufacturer="DeltaXY"
    UpgradeCode="{7C60A5D6-1C96-4BE3-A2BE-5A29A8FBE8B2}">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64"
             Description="AgentXL — document-to-Excel agent"
             Comments="Reads source documents and maps them into Excel with traceability." />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="low" />

    <!-- After install: extract payload archive -->
    <SetProperty
      Id="ExtractPayload"
      Sequence="execute"
      Before="ExtractPayload"
      Value="&quot;[System64Folder]tar.exe&quot; -xzf &quot;[INSTALLFOLDER]agentxl-payload.tar.gz&quot; -C &quot;[INSTALLFOLDER]&quot;" />
    <CustomAction
      Id="ExtractPayload"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="check"
      Impersonate="no" />

    <!-- After extract: run install-agentxl.ps1 -->
    <SetProperty
      Id="RunInstallScript"
      Sequence="execute"
      Before="RunInstallScript"
      Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]install-agentxl.ps1&quot; -InstallDir &quot;[INSTALLFOLDER]&quot;" />
    <CustomAction
      Id="RunInstallScript"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="check"
      Impersonate="no" />

    <!-- After extract: remove the archive to free disk space -->
    <SetProperty
      Id="CleanupArchive"
      Sequence="execute"
      Before="CleanupArchive"
      Value="&quot;[System64Folder]cmd.exe&quot; /c del /q &quot;[INSTALLFOLDER]agentxl-payload.tar.gz&quot;" />
    <CustomAction
      Id="CleanupArchive"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <!-- Uninstall: run uninstall script -->
    <SetProperty
      Id="RunUninstallScript"
      Sequence="execute"
      Before="RunUninstallScript"
      Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]uninstall-agentxl.ps1&quot;" />
    <CustomAction
      Id="RunUninstallScript"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <!-- Launch from finish dialog -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch AgentXL" />
    <Property Id="WixShellExecTarget" Value="[#LaunchOnboardingFile]" />
    <CustomAction Id="LaunchOnboarding" BinaryKey="WixCA" DllEntry="WixShellExec" Impersonate="yes" Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="ExtractPayload" After="InstallFiles">NOT Installed OR REINSTALL</Custom>
      <Custom Action="RunInstallScript" After="ExtractPayload">NOT Installed OR REINSTALL</Custom>
      <Custom Action="CleanupArchive" After="RunInstallScript">NOT Installed OR REINSTALL</Custom>
      <Custom Action="RunUninstallScript" Before="RemoveFiles">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

    <UI>
      <UIRef Id="WixUI_Minimal" />
      <UIRef Id="WixUI_ErrorProgressText" />
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchOnboarding">
        WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed
      </Publish>
    </UI>

    <!-- Directory structure -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="AgentXL">
          <Directory Id="MANIFESTDIR" Name="manifest" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AgentXLMenuDir" Name="AgentXL" />
      </Directory>
      <Directory Id="DesktopFolder" />
    </Directory>

    <!-- Main feature -->
    <Feature Id="MainFeature" Title="AgentXL" Level="1">
      <ComponentRef Id="PayloadArchive" />
      <ComponentRef Id="CmpInstallScript" />
      <ComponentRef Id="CmpUninstallScript" />
      <ComponentRef Id="CmpPostInstallTxt" />
      <ComponentRef Id="CmpInstallationInfo" />
      <ComponentRef Id="CmpLaunchOnboarding" />
      <ComponentRef Id="CmpStartAgentXL" />
      <ComponentRef Id="CmpAgentXLLogin" />
      <ComponentRef Id="CmpOpenTaskpane" />
      <ComponentRef Id="CmpOpenExcel" />
      <ComponentRef Id="ManifestFiles" />
      <ComponentRef Id="StartMenuShortcuts" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- Payload archive (the big file) -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="PayloadArchive" Guid="*" Win64="yes">
        <File Id="PayloadTarGz" KeyPath="yes" Source="$(var.StagingRoot)\agentxl-payload.tar.gz" />
      </Component>

      <Component Id="CmpInstallScript" Guid="*" Win64="yes">
        <File Id="InstallScript" KeyPath="yes" Source="$(var.StagingRoot)\install-agentxl.ps1" />
      </Component>
      <Component Id="CmpUninstallScript" Guid="*" Win64="yes">
        <File Id="UninstallScript" KeyPath="yes" Source="$(var.StagingRoot)\uninstall-agentxl.ps1" />
      </Component>
      <Component Id="CmpPostInstallTxt" Guid="*" Win64="yes">
        <File Id="PostInstallTxt" KeyPath="yes" Source="$(var.StagingRoot)\POST_INSTALL.txt" />
      </Component>
      <Component Id="CmpInstallationInfo" Guid="*" Win64="yes">
        <File Id="InstallationInfoTxt" KeyPath="yes" Source="$(var.StagingRoot)\INSTALLATION_INFO.txt" />
      </Component>

      <Component Id="CmpLaunchOnboarding" Guid="*" Win64="yes">
        <File Id="LaunchOnboardingFile" KeyPath="yes" Source="$(var.StagingRoot)\Launch AgentXL Onboarding.cmd" />
      </Component>
      <Component Id="CmpStartAgentXL" Guid="*" Win64="yes">
        <File Id="StartAgentXLFile" KeyPath="yes" Source="$(var.StagingRoot)\Start AgentXL.cmd" />
      </Component>
      <Component Id="CmpAgentXLLogin" Guid="*" Win64="yes">
        <File Id="AgentXLLoginFile" KeyPath="yes" Source="$(var.StagingRoot)\AgentXL Login.cmd" />
      </Component>
      <Component Id="CmpOpenTaskpane" Guid="*" Win64="yes">
        <File Id="OpenTaskpaneFile" KeyPath="yes" Source="$(var.StagingRoot)\Open AgentXL Taskpane.cmd" />
      </Component>
      <Component Id="CmpOpenExcel" Guid="*" Win64="yes">
        <File Id="OpenExcelFile" KeyPath="yes" Source="$(var.StagingRoot)\Open Excel with AgentXL.cmd" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="MANIFESTDIR">
      <Component Id="ManifestFiles" Guid="*" Win64="yes">
        <File Id="ManifestXml" KeyPath="yes" Source="$(var.StagingRoot)\manifest\manifest.xml" />
      </Component>
    </DirectoryRef>

    <!-- Start Menu shortcuts -->
    <DirectoryRef Id="AgentXLMenuDir">
      <Component Id="StartMenuShortcuts" Guid="*" Win64="yes">
        <Shortcut Id="LaunchShortcut" Name="AgentXL" Target="[#LaunchOnboardingFile]"
                  Description="Start AgentXL and open Excel" WorkingDirectory="INSTALLFOLDER" />
        <Shortcut Id="LoginShortcut" Name="AgentXL Login" Target="[#AgentXLLoginFile]"
                  Description="Sign in to your AI provider" WorkingDirectory="INSTALLFOLDER" />
        <Shortcut Id="ServerShortcut" Name="Start AgentXL Server" Target="[#StartAgentXLFile]"
                  Description="Start the local AgentXL server" WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\DeltaXY\AgentXL" Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Desktop shortcut -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="*" Win64="yes">
        <Shortcut Id="DesktopLaunchShortcut" Name="AgentXL" Target="[#LaunchOnboardingFile]"
                  Description="Start AgentXL and open Excel" WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\DeltaXY\AgentXL" Name="Desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

  </Product>
</Wix>
