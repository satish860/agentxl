<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="AgentXL"
    Language="1033"
    Version="$(var.AppVersion)"
    Manufacturer="DeltaXY"
    UpgradeCode="{7C60A5D6-1C96-4BE3-A2BE-5A29A8FBE8B2}">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64"
             Description="AgentXL — document-to-Excel agent"
             Comments="Reads source documents and maps them into Excel with traceability." />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  Schedule="afterInstallInitialize" />
    <MediaTemplate EmbedCab="yes" CompressionLevel="low" />

    <!-- ─── Upgrade: clean old extracted payload before re-extracting ──── -->
    <SetProperty
      Id="CleanOldPayload"
      Sequence="execute"
      Before="CleanOldPayload"
      Value="&quot;[System64Folder]cmd.exe&quot; /c rmdir /s /q &quot;[INSTALLFOLDER]app&quot; &amp; rmdir /s /q &quot;[INSTALLFOLDER]runtime&quot;" />
    <CustomAction
      Id="CleanOldPayload"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <!-- ─── Install: extract payload archive ───────────────────────────── -->
    <SetProperty
      Id="ExtractPayload"
      Sequence="execute"
      Before="ExtractPayload"
      Value="&quot;[System64Folder]tar.exe&quot; -xzf &quot;[INSTALLFOLDER]agentxl-payload.tar.gz&quot; -C &quot;[INSTALLFOLDER].&quot;" />
    <CustomAction
      Id="ExtractPayload"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="check"
      Impersonate="no" />

    <!-- ─── Install: configure Excel add-in ────────────────────────────── -->
    <SetProperty
      Id="RunInstallScript"
      Sequence="execute"
      Before="RunInstallScript"
      Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]install-agentxl.ps1&quot; -InstallDir &quot;[INSTALLFOLDER].&quot;" />
    <CustomAction
      Id="RunInstallScript"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <!-- ─── Install: remove archive to free disk space ─────────────────── -->
    <SetProperty
      Id="CleanupArchive"
      Sequence="execute"
      Before="CleanupArchive"
      Value="&quot;[System64Folder]cmd.exe&quot; /c del /q &quot;[INSTALLFOLDER]agentxl-payload.tar.gz&quot;" />
    <CustomAction
      Id="CleanupArchive"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <!-- ─── Uninstall: run cleanup script ──────────────────────────────── -->
    <SetProperty
      Id="RunUninstallScript"
      Sequence="execute"
      Before="RunUninstallScript"
      Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]uninstall-agentxl.ps1&quot;" />
    <CustomAction
      Id="RunUninstallScript"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <!-- ─── Uninstall: remove extracted dirs ───────────────────────────── -->
    <SetProperty
      Id="CleanExtractedDirs"
      Sequence="execute"
      Before="CleanExtractedDirs"
      Value="&quot;[System64Folder]cmd.exe&quot; /c rmdir /s /q &quot;[INSTALLFOLDER]app&quot; &amp; rmdir /s /q &quot;[INSTALLFOLDER]runtime&quot;" />
    <CustomAction
      Id="CleanExtractedDirs"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <!-- ─── Finish dialog: launch AgentXL ──────────────────────────────── -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch AgentXL in Excel" />
    <Property Id="WixShellExecTarget" Value="[#LaunchOnboardingFile]" />
    <CustomAction Id="LaunchOnboarding" BinaryKey="WixCA" DllEntry="WixShellExec" Impersonate="yes" Return="ignore" />

    <!-- ─── Execution sequence ─────────────────────────────────────────── -->
    <InstallExecuteSequence>
      <!-- On install or upgrade: clean old → extract → configure → cleanup archive -->
      <Custom Action="CleanOldPayload" After="InstallFiles">NOT REMOVE~="ALL"</Custom>
      <Custom Action="ExtractPayload" After="CleanOldPayload">NOT REMOVE~="ALL"</Custom>
      <Custom Action="RunInstallScript" After="ExtractPayload">NOT REMOVE~="ALL"</Custom>
      <Custom Action="CleanupArchive" After="RunInstallScript">NOT REMOVE~="ALL"</Custom>
      <!-- On uninstall: run cleanup script, then remove extracted dirs -->
      <Custom Action="RunUninstallScript" Before="RemoveFiles">REMOVE~="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="CleanExtractedDirs" After="RunUninstallScript">REMOVE~="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

    <UI>
      <UIRef Id="WixUI_Minimal" />
      <UIRef Id="WixUI_ErrorProgressText" />
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchOnboarding">
        WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed
      </Publish>
    </UI>

    <!-- ─── Directory structure ────────────────────────────────────────── -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="AgentXL">
          <Directory Id="MANIFESTDIR" Name="manifest" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AgentXLMenuDir" Name="AgentXL" />
      </Directory>
      <Directory Id="DesktopFolder" />
    </Directory>

    <!-- ─── Main feature ──────────────────────────────────────────────── -->
    <Feature Id="MainFeature" Title="AgentXL" Level="1">
      <ComponentRef Id="PayloadArchive" />
      <ComponentRef Id="CmpInstallScript" />
      <ComponentRef Id="CmpUninstallScript" />
      <ComponentRef Id="CmpPostInstallTxt" />
      <ComponentRef Id="CmpInstallationInfo" />
      <ComponentRef Id="CmpLaunchVbs" />
      <ComponentRef Id="CmpLoginVbs" />
      <ComponentRef Id="ManifestFiles" />
      <ComponentRef Id="StartMenuShortcuts" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- ─── Files ─────────────────────────────────────────────────────── -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="PayloadArchive" Guid="*" Win64="yes">
        <File Id="PayloadTarGz" KeyPath="yes" Source="$(var.StagingRoot)\agentxl-payload.tar.gz" />
      </Component>

      <Component Id="CmpInstallScript" Guid="*" Win64="yes">
        <File Id="InstallScript" KeyPath="yes" Source="$(var.StagingRoot)\install-agentxl.ps1" />
      </Component>
      <Component Id="CmpUninstallScript" Guid="*" Win64="yes">
        <File Id="UninstallScript" KeyPath="yes" Source="$(var.StagingRoot)\uninstall-agentxl.ps1" />
      </Component>
      <Component Id="CmpPostInstallTxt" Guid="*" Win64="yes">
        <File Id="PostInstallTxt" KeyPath="yes" Source="$(var.StagingRoot)\POST_INSTALL.txt" />
      </Component>
      <Component Id="CmpInstallationInfo" Guid="*" Win64="yes">
        <File Id="InstallationInfoTxt" KeyPath="yes" Source="$(var.StagingRoot)\INSTALLATION_INFO.txt" />
      </Component>

      <Component Id="CmpLaunchVbs" Guid="*" Win64="yes">
        <File Id="LaunchVbsFile" KeyPath="yes" Source="$(var.StagingRoot)\AgentXL.vbs" />
      </Component>
      <Component Id="CmpLoginVbs" Guid="*" Win64="yes">
        <File Id="LoginVbsFile" KeyPath="yes" Source="$(var.StagingRoot)\AgentXL Login.vbs" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="MANIFESTDIR">
      <Component Id="ManifestFiles" Guid="*" Win64="yes">
        <File Id="ManifestXml" KeyPath="yes" Source="$(var.StagingRoot)\manifest\manifest.xml" />
      </Component>
    </DirectoryRef>

    <!-- ─── Start Menu ────────────────────────────────────────────────── -->
    <DirectoryRef Id="AgentXLMenuDir">
      <Component Id="StartMenuShortcuts" Guid="*" Win64="yes">
        <Shortcut Id="LaunchShortcut" Name="AgentXL" Target="[SystemFolder]wscript.exe"
                  Arguments="&quot;[INSTALLFOLDER]AgentXL.vbs&quot;"
                  Description="Start AgentXL and open Excel" WorkingDirectory="INSTALLFOLDER" />
        <Shortcut Id="LoginShortcut" Name="AgentXL Login" Target="[SystemFolder]wscript.exe"
                  Arguments="&quot;[INSTALLFOLDER]AgentXL Login.vbs&quot;"
                  Description="Sign in to your AI provider" WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\DeltaXY\AgentXL" Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- ─── Desktop ───────────────────────────────────────────────────── -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="*" Win64="yes">
        <Shortcut Id="DesktopLaunchShortcut" Name="AgentXL" Target="[SystemFolder]wscript.exe"
                  Arguments="&quot;[INSTALLFOLDER]AgentXL.vbs&quot;"
                  Description="Start AgentXL and open Excel" WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\DeltaXY\AgentXL" Name="Desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

  </Product>
</Wix>
