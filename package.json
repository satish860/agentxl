{
  "name": "agentxl",
  "version": "1.0.0",
  "description": "Open-source AI agent that lives inside Microsoft Excel",
  "author": "DeltaXY <hello@deltaxy.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deltaxy-ai/agentxl"
  },
  "keywords": [
    "excel",
    "ai",
    "agent",
    "office",
    "claude",
    "openai",
    "spreadsheet"
  ],
  "bin": {
    "agentxl": "./bin/agentxl.js"
  },
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc && npm run build:taskpane",
    "build:server": "tsc",
    "build:taskpane": "cd taskpane && npx vite build",
    "dev:taskpane": "cd taskpane && npx vite dev",
    "start": "node dist/server/index.js",
    "test": "npx tsx tests/certs.test.ts"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.52.12",
    "@sinclair/typebox": "^0.34.11",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "@microsoft/office-js": "^1.1.110",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "lucide-react": "^0.564.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
